{
    "manifest_version": 3,
    "name": "Chess LLM Agent",
    "version": "1.0.0",
    "action": {
        "default_popup": "index.html"
    },
    "options_page": "offscreen.html",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "offscreen"
    ],
    "background": {
        "service_worker": "src/background.ts",
        "type": "module"
    },
    "host_permissions": [
        "*://*.chess.com/*",
        "https://explorer.lichess.ovh/*",
        "https://generativelanguage.googleapis.com/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "*://*.chess.com/*"
            ],
            "js": [
                "src/content.ts"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["offscreen.html", "stockfish.js", "stockfish.wasm"],
            "matches": ["<all_urls>"]
        }
    ]
}